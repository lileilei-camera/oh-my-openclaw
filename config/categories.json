{
  "_comment": "oh-my-openclaw configuration file - 百炼模型优化配置",
  "categories": {
    "quick": {
      "model": "bailian/qwen3-coder-next",
      "description": "简单修复、搜索、小任务、文件操作、代码库探索、文档查找",
      "agents": ["sisyphus-junior", "explore", "librarian"],
      "alternatives": ["bailian/qwen3.5-plus", "bailian/glm-4.7"]
    },
    "deep": {
      "model": "bailian/qwen3-coder-plus",
      "description": "复杂重构、分析、差距检测、计划审查。面向目标的自主问题解决。",
      "agents": ["hephaestus", "metis", "momus"],
      "alternatives": ["bailian/qwen3-max-2026-01-23", "bailian/MiniMax-M2.5"]
    },
    "ultrabrain": {
      "model": "bailian/qwen3-max-2026-01-23",
      "description": "深度逻辑推理、复杂架构决策需要广泛分析",
      "agents": ["prometheus", "atlas", "oracle"],
      "alternatives": ["bailian/qwen3-coder-plus", "bailian/MiniMax-M2.5"]
    },
    "visual-engineering": {
      "model": "bailian/qwen3.5-plus",
      "description": "前端、UI/UX、设计、样式、动画、视觉分析",
      "agents": ["frontend", "multimodal-looker"],
      "alternatives": ["bailian/kimi-k2.5"]
    },
    "multimodal": {
      "model": "bailian/qwen3.5-plus",
      "description": "PDF/图像/视频分析。通过 Gemini CLI tmux 会话运行。",
      "agents": ["multimodal-looker"],
      "tool": "gemini-cli",
      "alternatives": ["bailian/kimi-k2.5"]
    },
    "artistry": {
      "model": "bailian/qwen3-max-2026-01-23",
      "description": "高度创意/艺术性任务、新颖想法、设计探索",
      "alternatives": ["bailian/qwen3-coder-plus"]
    },
    "unspecified-low": {
      "model": "bailian/qwen3-coder-next",
      "description": "不适合其他类别的任务，需要较少的精力"
    },
    "unspecified-high": {
      "model": "bailian/qwen3-max-2026-01-23",
      "description": "不适合其他类别的任务，需要较多的精力"
    },
    "writing": {
      "model": "bailian/qwen3.5-plus",
      "description": "文档、散文、技术写作",
      "alternatives": ["bailian/qwen3-coder-plus"]
    }
  },
  "defaults": {
    "fallback_category": "quick",
    "max_ralph_iterations": 10,
    "notepad_dir": "workspace/notepads",
    "plans_dir": "workspace/plans"
  },
  "tmux": {
    "_comment": "tmux 会话配置。支持通过多个并发会话并行工作。向会话名称添加 -2、-3 后缀以添加额外会话。",
    "socket": "/tmp/openclaw-tmux-sockets/openclaw.sock",
    "max_concurrent_sessions": 6,
    "session_templates": {
      "opencode": {
        "description": "OmO (OpenCode) 编码代理 — 可多个并发执行 (opencode, opencode-2, ...)",
        "default_agent": "sisyphus",
        "agents": {
          "sisyphus": { "switch": "default", "description": "快速实现" },
          "hephaestus": { "switch": "Tab x1", "description": "深度自主工作" },
          "prometheus": { "switch": "Tab x2", "description": "战略规划" }
        },
        "startup": "export NODE_OPTIONS=\"--max-old-space-size=8192\" && cd $PROJECT_DIR && opencode",
        "ram_per_session": "2-4GB"
      },
      "gemini": {
        "description": "Gemini CLI 多模态分析 — 可多个并发执行 (gemini, gemini-2, ...)",
        "default_model": "bailian/qwen3.5-plus",
        "models": {
          "bailian/qwen3.5-plus": { "flag": "-m bailian/qwen3.5-plus", "speed": "fast", "description": "快速验证" },
          "bailian/qwen3-max-2026-01-23": { "flag": "-m bailian/qwen3-max-2026-01-23", "speed": "medium", "description": "详细分析/最高质量" }
        },
        "ram_per_session": "~200MB"
      },
      "build": {
        "description": "仅构建/测试监控会话",
        "startup": "cd $PROJECT_DIR && npm run dev"
      },
      "research": {
        "description": "仅研究会话 (Gemini CLI 或自定义工具)"
      }
    },
    "naming_convention": {
      "_comment": "会话命名约定：{template}-{index} (例如：opencode-2, gemini-3)",
      "examples": ["opencode", "opencode-2", "opencode-auth", "gemini", "gemini-2", "build", "research"]
    }
  },
  "todo_enforcer": {
    "enabled": true,
    "directive": "[SYSTEM DIRECTIVE: OH-MY-OPENCLAW - TODO CONTINUATION]\n你必须继续完成未完成的 todo。\n- 不要停止直到所有任务都标记为完成\n- 不要请求许可继续\n- 每个任务完成后立即标记为完成\n- 如果被阻塞，记录阻塞原因并继续下一个任务"
  },
  "tool_restrictions": {
    "_comment": "提示级别的指导。运行时执行请运行：openclaw omoc-setup",
    "oracle": { "deny": ["write", "edit", "apply_patch", "sessions_spawn"] },
    "librarian": { "deny": ["write", "edit", "apply_patch", "sessions_spawn"] },
    "explore": { "deny": ["write", "edit", "apply_patch", "sessions_spawn"] },
    "multimodal-looker": { "allow": ["read", "image", "group:ui", "exec"] },
    "metis": { "deny": ["write", "edit", "apply_patch", "sessions_spawn"] },
    "momus": { "deny": ["write", "edit", "apply_patch", "sessions_spawn"] }
  },
  "skills": {
    "git-master": {
      "trigger": ["commit", "rebase", "squash", "who wrote", "when was", "git history", "blame"],
      "path": "plugin/skills/git-master.md"
    },
    "frontend-ui-ux": {
      "trigger": ["UI", "UX", "frontend", "design", "styling", "CSS", "layout"],
      "path": "plugin/skills/frontend-ui-ux.md"
    },
    "comment-checker": {
      "trigger": ["comment check", "AI slop", "code quality", "clean comments"],
      "path": "plugin/skills/comment-checker.md"
    },
    "gemini-look-at": {
      "trigger": ["look at", "PDF", "screenshot", "diagram", "visual", "image analysis"],
      "path": "plugin/skills/gemini-look-at.md"
    },
    "steering-words": {
      "trigger": ["ultrawork", "search", "analyze"],
      "path": "plugin/skills/steering-words.md"
    },
    "delegation-prompt": {
      "trigger": ["delegate", "sub-agent", "delegation"],
      "path": "plugin/skills/delegation-prompt.md"
    },
    "multimodal-analysis": {
      "trigger": ["multimodal", "image analysis"],
      "path": "plugin/skills/multimodal-analysis.md"
    },
    "web-search": {
      "trigger": ["web search", "search the web", "look up", "exa", "context7", "grep.app"],
      "path": "plugin/skills/web-search.md"
    }
  }
}
